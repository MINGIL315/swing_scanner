# 로깅 레벨 (DEBUG / INFO / WARNING / ERROR)
LOG_LEVEL=INFO

# FastAPI 대시보드 바인딩
API_HOST=127.0.0.1
API_PORT=8000

# Windows 콘솔 한글 출력 (cp949 환경에서 필수)
PYTHONIOENCODING=utf-8

# 데이터 fetch 최대 병렬 워커 수 (기본: 4)
# FETCH_MAX_WORKERS=4

# SQLite DB 경로 (기본: data/scanner.db)
# SCANNER_DB_PATH=data/scanner.db

# KRX OpenAPI 인증키 (https://openapi.krx.co.kr 에서 발급)
KRX_API_KEY=발급받은_KRX_OpenAPI_인증키
