# 로깅 레벨 (DEBUG / INFO / WARNING / ERROR)
LOG_LEVEL=INFO

# FastAPI 대시보드 바인딩
API_HOST=127.0.0.1
API_PORT=8000

# Windows 콘솔 한글 출력 (cp949 환경에서 필수)
PYTHONIOENCODING=utf-8

# 데이터 fetch 최대 병렬 워커 수 (기본: 4)
# FETCH_MAX_WORKERS=4

# SQLite DB 경로 (기본: data/scanner.db)
# SCANNER_DB_PATH=data/scanner.db

# 한국투자증권(KIS) OpenAPI 앱키/시크릿
# https://apiportal.koreainvestment.com 에서 실전 앱 등록 후 발급
# 한국 주식 데이터 (일봉/주봉/재무/분봉) 수집에 사용
KIS_APP_KEY=발급받은_KIS_앱키
KIS_APP_SECRET=발급받은_KIS_앱시크릿

# (선택) KIS 도메인 — 기본값 = 실전. 모의로 바꾸려면:
# KIS_BASE_URL=https://openapivts.koreainvestment.com:29443
